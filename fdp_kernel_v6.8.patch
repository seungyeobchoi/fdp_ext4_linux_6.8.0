 {
@@ -715,6 +767,32 @@ SYSCALL_DEFINE4(pwrite64, unsigned int,
 	return ksys_pwrite64(fd, buf, count, pos);
 }
 
+ssize_t ksys_pwrite64_p(unsigned int fd, const char __user *buf,
+		      size_t count, loff_t pos, unsigned int pli)
+{
+	struct fd f;
+	ssize_t ret = -EBADF;
+
+	if (pos < 0)
+		return -EINVAL;
+
+	f = fdget(fd);
+	if (f.file) {
+		ret = -ESPIPE;
+		if (f.file->f_mode & FMODE_PWRITE) 
+			ret = vfs_write_p(f.file, buf, count, &pos, pli);
+		fdput(f);
+	}
+
+	return ret;
+}
+
+SYSCALL_DEFINE5(pwrite64_p, unsigned int, fd, const char __user *, buf,
+			 size_t, count, loff_t, pos, unsigned int, pli)
+{
+	return ksys_pwrite64_p(fd, buf, count, pos, pli);
+}
