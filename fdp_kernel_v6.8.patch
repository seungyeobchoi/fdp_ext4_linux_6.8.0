@@ -53,6 +53,35 @@ static void blk_mq_try_issue_list_direct
 static int blk_hctx_poll(struct request_queue *q, struct blk_mq_hw_ctx *hctx,
 			 struct io_comp_batch *iob, unsigned int flags);
 
+static inline struct blk_mq_ctx *fdp_pick_ctx_for_pli(
+			 struct blk_mq_hw_ctx *hctx,
+			 struct blk_mq_ctx *orig_ctx, u16 pli)
+{
+	unsigned int n = hctx->nr_ctx;
+	unsigned int per, start, off, idx;
+	unsigned int cpu_hint;
+
+	if (n == 0)
+		return orig_ctx;
+
+	per = n / FDP_MAX_PLI;
+
+	if (pli == RQ_PLI_NONE || pli >= FDP_MAX_PLI || per == 0)
+		return orig_ctx;
+ 
+	start = pli * per;
+	if (start >= n)
+		start = n - 1;
+
+	cpu_hint = orig_ctx->cpu;
+	off = cpu_hint % per;
+	idx = start + off;
+	if (idx >= n)
+		idx = start;
+
+	return hctx->ctxs[idx];
+}
+
